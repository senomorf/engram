# Local release signing (optional). Copy to keystore.properties (git-ignored) and fill in
# to build a signed release APK locally: ./gradlew :app:assembleRelease
# Leave it absent and assembleRelease produces an unsigned APK (fine for dev/PR CI).
# CI reads the same names from environment/secrets, so keep them in sync.
#
# ENGRAM_KEYSTORE_FILE: path to the .jks keystore (absolute, or relative to repo root)
# The other three are the store password, key alias, and key password.
ENGRAM_KEYSTORE_FILE=/absolute/path/to/engram-release.jks
ENGRAM_KEYSTORE_PASSWORD=changeit
ENGRAM_KEY_ALIAS=engram
ENGRAM_KEY_PASSWORD=changeit
